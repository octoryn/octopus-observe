{
  "name": "octopus-observe",
  "version": "0.7.0",
  "description": "Observe: standalone, governed, auditable intake and normalization — raw external events into trusted, canonical, immutable observations.",
  "license": "Apache-2.0",
  "author": "Octoryn",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octoryn/octopus-observe.git"
  },
  "homepage": "https://github.com/octoryn/octopus-observe#readme",
  "bugs": {
    "url": "https://github.com/octoryn/octopus-observe/issues"
  },
  "keywords": [
    "observation",
    "normalization",
    "intake",
    "events",
    "audit",
    "tamper-evident",
    "provenance",
    "ai-native",
    "octopus",
    "octoryn"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sqlite": {
      "types": "./dist/storage/sqlite.d.ts",
      "default": "./dist/storage/sqlite.js"
    },
    "./conformance": {
      "types": "./dist/conformance.d.ts",
      "default": "./dist/conformance.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "octopus-observe": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "coverage": "node --import tsx --test --experimental-test-coverage tests/*.test.ts",
    "example": "tsx examples/ingest.ts",
    "cli": "tsx src/cli.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run typecheck && npm run format:check && npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  }
}
